		"url": "git+ssh://git@github.com/PandaNocturne/obsidian-wannianli.git"
	},
	"bugs": {
		"url": "https://github.com/PandaNocturne/obsidian-wannianli/issues"
	},
	"homepage": "https://github.com/PandaNocturne/obsidian-wannianli#readme",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"less": "^4.2.2",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
